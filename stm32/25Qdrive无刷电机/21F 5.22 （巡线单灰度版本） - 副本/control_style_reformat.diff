-/**
- * @brief  主循环调用的 MaixCam 坐标外环，固定周期发送双轴速度命令。
- * @note   QD4310 驱动含同步反馈等待，禁止在定时器中断中调用。
- */
-void Vision_Control_Task(void)
-{
-    float x_actual;
-    float y_actual;
-    float x_current;
-    float y_speed;
-    uint32_t now;
-
-    if (Vision_Control_Active == 0U)
-    {
-        if ((Vision_Both_Start_Request != 0U) &&
-            (Vision_Control_IsTargetValid() != 0U))
-        {
-            Vision_Control_Start();
-            Vision_Both_Start_Request = 0U;
-        }
-        return;
-    }
-
-    now = HAL_GetTick();
-    if ((now - Vision_Last_Control_Tick) < VISION_CONTROL_PERIOD_MS) return;
-    Vision_Last_Control_Tick = now;
-
-    if (Vision_Control_IsTargetValid() == 0U)
-    {
-        Vision_SetOutput(0.0f, 0.0f);
-        Vision_Control_Active = 0U;
-        Vision_Target_Lost = 1U;
-        Vision_PID_Clear();
-        return;
-    }
-
-    x_current = 0.0f;
-    y_speed = 0.0f;
-
-    if (Vision_X_Motor_Enabled != 0U)
-    {
-        Vision_X_FilterUpdate();
-        set_pid_target(&pid_dr4310X, Vision_X_Target_Filtered);
-        x_actual = Vision_X_Laser_Filtered;
-        x_current = dr4310_pid_realize(&pid_dr4310X,
-                                       x_actual,
-                                       VISION_X_CURRENT_LIMIT_A);
-        x_current = Vision_X_CurrentLimit(x_current * VISION_X_DIRECTION);
-    }
-    else
-    {
-        Vision_X_StateClear();
-    }
-
-    if (Vision_Y_Motor_Enabled != 0U)
-    {
-        set_pid_target(&pid_dr4310Y, (float)maixcam_target_y);
-        y_actual = (float)maixcam_laser_y;
-        y_speed = dr4310_pid_realize(&pid_dr4310Y,
-                                     y_actual,
-                                     VISION_Y_SPEED_LIMIT_RPM) * VISION_Y_DIRECTION;
-    }
-    else
-    {
-        PID_Clear_State(&pid_dr4310Y);
-    }
-    Vision_SetOutput(x_current, y_speed);
-}
