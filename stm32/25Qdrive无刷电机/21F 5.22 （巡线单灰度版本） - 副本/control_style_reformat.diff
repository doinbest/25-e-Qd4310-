-void Vision_Control_Task(void)
-{
-    uint32_t now = HAL_GetTick();
-    uint8_t index;
-
-    Vision_Control_UpdateCameraLink();
-
-    /* X-rate tuning does not require a vision target, only fresh WT61 data. */
-    if (Vision_Rate_Debug_Active != 0U)
-    {
-        if ((now - Vision_Last_Inner_Tick) >= VISION_INNER_PERIOD_MS)
-        {
-            Vision_Last_Inner_Tick = now;
-            Vision_XRateInnerStep(Vision_Rate_Debug_Target_Dps);
-        }
-        return;
-    }
-
-    /* A missing serial stream is a safety fault, never a reason to scan. */
-    if (Vision_FrameFresh() == 0U)
-    {
-        if ((Vision_X_Motor_Enabled != 0U) || (Vision_Y_Motor_Enabled != 0U))
-        {
-            Vision_AxisStopOutput(&Vision_Axes[VISION_AXIS_X]);
-            Vision_AxisStopOutput(&Vision_Axes[VISION_AXIS_Y]);
