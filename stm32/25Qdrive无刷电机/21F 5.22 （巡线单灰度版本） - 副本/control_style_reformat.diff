-/* X uses QD4310 current mode for the heavy load; Y remains QD low-speed mode. */
-static void Vision_AxisSendCommand(Vision_Axis_t *axis, float command)
-{
-    if (*(axis->enabled) == 0U) return;
-    if (axis == &Vision_Axes[VISION_AXIS_Y])
-    {
-        command = Limit_Float(command, -VISION_QD_SPEED_LIMIT_RPM, VISION_QD_SPEED_LIMIT_RPM);
-        axis->last_speed_command_rpm = command;
-        QD4310_SetLowSpeed(axis->motor, VISION_Y_SPEED_SIGN * command);
-    }
-}
