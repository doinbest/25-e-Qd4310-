-/* X: pixel PID -> target rate(deg/s), WT61 GZ -> rate PID -> current(A). */
-static void Vision_XRateInnerStep(float target_rate_dps)
-{
-    Vision_Axis_t *axis = &Vision_Axes[VISION_AXIS_X];
-    float current_command;
-    float current_change;
-
-    if (Vision_X_Motor_Enabled == 0U) return;
-    if (Vision_XImuFresh() == 0U)
-    {
-        Vision_AxisStopOutput(axis);
-        return;
-    }
-
-    target_rate_dps = Limit_Float(target_rate_dps,
-                                  -VISION_X_RATE_LIMIT_DPS,
-                                  VISION_X_RATE_LIMIT_DPS);
-    set_pid_target(&pid_dr4310X_rate, target_rate_dps);
-    current_command = pid_realize_limited(&pid_dr4310X_rate,
-                                          Vision_XGyroDps(),
-                                          VISION_X_CURRENT_LIMIT_A,
-                                          VISION_X_RATE_INTEGRAL_LIMIT,
-                                          VISION_X_RATE_DEADBAND_DPS);
-
-    current_change = Limit_Float(current_command - axis->last_speed_command_rpm,
-                                 -VISION_X_CURRENT_RAMP_A_PER_10MS,
-                                 VISION_X_CURRENT_RAMP_A_PER_10MS);
-    axis->last_speed_command_rpm += current_change;
-    axis->last_speed_command_rpm = Limit_Float(axis->last_speed_command_rpm,
-                                                -VISION_X_CURRENT_LIMIT_A,
-                                                VISION_X_CURRENT_LIMIT_A);
-    QD4310_SetCurrent(axis->motor,
-                      VISION_X_CURRENT_SIGN * axis->last_speed_command_rpm);
-}
-
-static void Vision_AxisOuterStep(Vision_Axis_Index_t index)
-{
-    Vision_Axis_t *axis = &Vision_Axes[index];
-    float target;
-    float actual;
-    float command;
-    float output_limit;
-
-    if (*(axis->enabled) == 0U) return;
-    if (axis->last_vision_frame_count == maixcam_frame_count) return;
-    axis->last_vision_frame_count = maixcam_frame_count;
-
-    target = Vision_AxisPixelTarget(index);
-    actual = Vision_AxisPixelActual(index);
-    if (axis->filter_ready == 0U)
-    {
-        axis->pixel_actual_filtered = actual;
-        axis->filter_ready = 1U;
-    }
-    else
-    {
-        axis->pixel_actual_filtered += VISION_FILTER_ALPHA *
-                                       (actual - axis->pixel_actual_filtered);
-    }
-    /* X PID output is target rate(deg/s); Y PID output is low-speed reference(rpm). */
-    set_pid_target(axis->pixel_pid, target);
-    output_limit = (index == VISION_AXIS_X) ? VISION_X_RATE_LIMIT_DPS :
-                                               VISION_QD_SPEED_LIMIT_RPM;
-    command = pid_realize_limited(axis->pixel_pid, axis->pixel_actual_filtered,
-                                  output_limit, VISION_PIXEL_INTEGRAL_LIMIT,
-                                  VISION_PIXEL_DEADBAND_PX);
-    axis->target_speed_rpm = command;
-}
-
