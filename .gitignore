JLinkLog.txt
JLinkSettings.ini
openocd.log
*.svd.tmp

# =========================================================
# Keil 本机用户文件（如果 EIDE 导出过 Keil 工程）
# =========================================================
*.uvguix.*
*.uvguix
*.uvopt
*.uvoptx
*.crf
*.lnp
*.iex
*.build_log.htm

# Keil Pack 安装缓存：由本机 Keil 环境提供，不属于工程源码。
# 保留 .uvprojx、.ioc、startup_*.s、.sct 和 .ld 等可复现工程配置。
**/MDK-ARM/.pack/

# =========================================================
# Python / MaixVision 缓存
# =========================================================
maixcam2/dist/
**pycache**/
*.py[cod]
*$py.class

.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Python 虚拟环境
.venv/
venv/
env/

# =========================================================
# 本地密钥和私有配置
# =========================================================
.env
.env.*
!.env.example

secrets.*
*.key
*.pem

# =========================================================
# 日志、临时文件和备份
# =========================================================
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# 临时粘贴代码
tempCodeRunnerFile.py

# =========================================================
# 操作系统产生的文件
# =========================================================
.DS_Store
Thumbs.db
Desktop.ini

